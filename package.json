{
  "name": "@wyre-technology/spamtitan-mcp",
  "version": "1.0.0",
  "description": "MCP server for SpamTitan email security — manage quarantine, allowlists, blocklists, and view email stats",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "spamtitan-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/spamtitan-mcp.git"
  },
  "keywords": [
